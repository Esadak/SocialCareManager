@page "/serviceusers/{Id:guid}"
@rendermode InteractiveServer
@using System.Net.Http.Json
@using System.Net.Http.Headers
@using SocialCareManager.Web.Services
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject AuthService AuthService

<h1>Service user details</h1>

@if (serviceUser is null)
{
    <p>Loading...</p>
}
else
{
    @if (!isEditing)
    {
        <h3>@serviceUser.FirstName @serviceUser.LastName</h3>
        <p><strong>Date of birth:</strong> @serviceUser.DateOfBirth.ToShortDateString()</p>

        <button class="btn btn-secondary mb-3" @onclick="StartEdit">
            Edit user
        </button>

        <button class="btn btn-danger mb-3 ms-2" @onclick="DeleteUser">
            Delete user
        </button>
    }
    else
    {
        <h4>Edit service user</h4>

        <div class="mb-3">
            <label class="form-label">First name</label>
            <input class="form-control" @bind="editServiceUser.FirstName" />
        </div>

        <div class="mb-3">
            <label class="form-label">Last name</label>
            <input class="form-control" @bind="editServiceUser.LastName" />
        </div>

        <div class="mb-3">
            <label class="form-label">Date of birth</label>
            <input type="date" class="form-control" @bind="editServiceUser.DateOfBirth" />
        </div>

        <button class="btn btn-primary me-2" @onclick="SaveUser">
            Save
        </button>

        <button class="btn btn-outline-secondary" @onclick="CancelEdit">
            Cancel
        </button>
    }

    <hr />

    <h4>Daily notes</h4>

    <div class="mb-3">
        <label class="form-label">Title</label>
        <input class="form-control" @bind="newNote.Title" />
    </div>

    <div class="mb-3">
        <label class="form-label">Content</label>
        <textarea class="form-control" @bind="newNote.Content"></textarea>
    </div>

    <button class="btn btn-primary mb-3" @onclick="CreateNote">
        Add Daily Note
    </button>

    @if (dailyNotes is null)
    {
        <p>Loading notes...</p>
    }
    else if (dailyNotes.Count == 0)
    {
        <p>No daily notes found.</p>
    }
    else
    {
        <ul>
            @foreach (var note in dailyNotes)
            {
                <li class="mb-3">
                    @if (editingNoteId == note.Id)
                    {
                        <div class="mb-2">
                            <label class="form-label">Title</label>
                            <input class="form-control" @bind="editNote.Title" />
                        </div>

                        <div class="mb-2">
                            <label class="form-label">Content</label>
                            <textarea class="form-control" @bind="editNote.Content"></textarea>
                        </div>

                        <button class="btn btn-primary btn-sm me-2" @onclick="SaveNote">
                            Save
                        </button>

                        <button class="btn btn-outline-secondary btn-sm" @onclick="CancelEditNote">
                            Cancel
                        </button>
                    }
                    else
                    {
                        <strong>@note.Title</strong><br />
                        @note.Content<br />

                        <button class="btn btn-secondary btn-sm mt-2 me-2" @onclick="() => StartEditNote(note)">
                            Edit
                        </button>

                        <button class="btn btn-danger btn-sm mt-2" @onclick="() => DeleteNote(note.Id)">
                            Delete
                        </button>
                    }
                </li>
            }
        </ul>
    }
}

@code {
    [Parameter]
    public Guid Id { get; set; }

    private Guid? editingNoteId;
    private EditDailyNoteDto editNote = new();

    private ServiceUserDto? serviceUser;
    private List<DailyNoteDto>? dailyNotes;
    private CreateDailyNoteDto newNote = new();
    private EditServiceUserDto editServiceUser = new();
    private bool isEditing;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsLoggedIn)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        SetAuthorizationHeader();
        await LoadData();
    }

    private void SetAuthorizationHeader()
    {
        Http.DefaultRequestHeaders.Authorization =
            new AuthenticationHeaderValue("Bearer", AuthService.AccessToken);
    }

    private async Task LoadData()
    {
        SetAuthorizationHeader();

        serviceUser = await Http.GetFromJsonAsync<ServiceUserDto>(
            $"http://localhost:5195/api/serviceusers/{Id}");

        dailyNotes = await Http.GetFromJsonAsync<List<DailyNoteDto>>(
            $"http://localhost:5195/api/serviceusers/{Id}/dailynotes");
    }

    private void StartEdit()
    {
        if (serviceUser is null)
            return;

        editServiceUser = new EditServiceUserDto
        {
            FirstName = serviceUser.FirstName,
            LastName = serviceUser.LastName,
            DateOfBirth = serviceUser.DateOfBirth
        };

        isEditing = true;
    }

    private void CancelEdit()
    {
        isEditing = false;
    }

    private async Task SaveUser()
    {
        SetAuthorizationHeader();

        var response = await Http.PutAsJsonAsync(
            $"http://localhost:5195/api/serviceusers/{Id}",
            editServiceUser);

        if (response.IsSuccessStatusCode)
        {
            serviceUser = await Http.GetFromJsonAsync<ServiceUserDto>(
                $"http://localhost:5195/api/serviceusers/{Id}");

            isEditing = false;
        }
    }

    private async Task DeleteUser()
    {
        SetAuthorizationHeader();

        var response = await Http.DeleteAsync(
            $"http://localhost:5195/api/serviceusers/{Id}");

        if (response.IsSuccessStatusCode)
        {
            Navigation.NavigateTo("/serviceusers");
        }
    }

    private async Task CreateNote()
    {
        SetAuthorizationHeader();

        var response = await Http.PostAsJsonAsync(
            $"http://localhost:5195/api/serviceusers/{Id}/dailynotes",
            newNote);

        if (response.IsSuccessStatusCode)
        {
            newNote = new CreateDailyNoteDto();
            await LoadData();
        }
    }

    private void StartEditNote(DailyNoteDto note)
    {
        editingNoteId = note.Id;

        editNote = new EditDailyNoteDto
        {
            Title = note.Title,
            Content = note.Content
        };
    }

    private void CancelEditNote()
    {
        editingNoteId = null;
        editNote = new EditDailyNoteDto();
    }

    private async Task SaveNote()
    {
        if (editingNoteId is null)
            return;

        SetAuthorizationHeader();

        var response = await Http.PutAsJsonAsync(
            $"http://localhost:5195/api/serviceusers/{Id}/dailynotes/{editingNoteId}",
            editNote);

        if (response.IsSuccessStatusCode)
        {
            editingNoteId = null;
            editNote = new EditDailyNoteDto();
            await LoadData();
        }
    }

    private async Task DeleteNote(Guid noteId)
    {
        var confirmed = await JS.InvokeAsync<bool>(
            "confirm",
            "Are you sure you want to delete this daily note?");

        if (!confirmed)
            return;

        SetAuthorizationHeader();

        var response = await Http.DeleteAsync(
            $"http://localhost:5195/api/serviceusers/{Id}/dailynotes/{noteId}");

        if (response.IsSuccessStatusCode)
        {
            await LoadData();
        }
    }

    public class ServiceUserDto
    {
        public Guid Id { get; set; }
        public string FirstName { get; set; } = string.Empty;
        public string LastName { get; set; } = string.Empty;
        public DateTime DateOfBirth { get; set; }
    }

    public class EditServiceUserDto
    {
        public string FirstName { get; set; } = string.Empty;
        public string LastName { get; set; } = string.Empty;
        public DateTime DateOfBirth { get; set; }
    }

    public class DailyNoteDto
    {
        public Guid Id { get; set; }
        public Guid ServiceUserId { get; set; }
        public string Title { get; set; } = string.Empty;
        public string Content { get; set; } = string.Empty;
        public DateTime CreatedAt { get; set; }
        public DateTime? UpdatedAt { get; set; }
    }

    public class CreateDailyNoteDto
    {
        public string Title { get; set; } = string.Empty;
        public string Content { get; set; } = string.Empty;
    }

    public class EditDailyNoteDto
    {
        public string Title { get; set; } = string.Empty;
        public string Content { get; set; } = string.Empty;
    }
}