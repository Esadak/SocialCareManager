@page "/serviceusers"
@rendermode InteractiveServer
@using SocialCareManager.Web.Dtos
@using SocialCareManager.Web.Services
@using SocialCareManager.Web.Services.Api
@inject AuthService AuthService
@inject ServiceUserService ServiceUserService
@inject NavigationManager Navigation

<div class="page-header">
    <div class="page-title">
        <i class="bi bi-people-fill"></i>
        <h1>Service Users</h1>
    </div>

    <div class="page-subtitle">
        Manage service users, personal information and care records.
    </div>
</div>

<div class="section-card mb-4">
    <div class="section-card-header">
        <i class="bi bi-person-plus-fill"></i>
        <h3>Add service user</h3>
    </div>

    <div class="mb-3">
        <label class="form-label">First name</label>
        <input class="form-control" @bind="newServiceUser.FirstName" />
    </div>

    <div class="mb-3">
        <label class="form-label">Last name</label>
        <input class="form-control" @bind="newServiceUser.LastName" />
    </div>

    <div class="mb-3">
        <label class="form-label">Date of birth</label>
        <input type="date" class="form-control" @bind="newServiceUser.DateOfBirth" />
    </div>

    <button class="btn btn-primary" @onclick="CreateServiceUser">
        Add Service User
    </button>
</div>

<div class="section-card mb-4">
    <div class="section-card-header">
        <i class="bi bi-search"></i>
        <h3>Search</h3>
    </div>

    <div class="mb-3">
        <input class="form-control"
               placeholder="Search by first name or last name..."
               @bind="searchText"
               @bind:event="oninput" />
    </div>

    <button class="btn btn-outline-secondary" @onclick="ClearSearch">
        Clear search
    </button>
</div>

@if (serviceUsers is null)
{
    <p>Loading...</p>
}
else if (FilteredServiceUsers.Count == 0)
{
    <p>No service users found.</p>
}
else
{
    <div class="table-card">
        <table class="table modern-table align-middle mb-0">
            <thead>
                <tr>
                    <th>First name</th>
                    <th>Last name</th>
                    <th>Date of birth</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in FilteredServiceUsers)
                {
                    <tr>
                        <td>
                            <a href="@($"/serviceusers/{user.Id}")">@user.FirstName</a>
                        </td>
                        <td>@user.LastName</td>
                        <td>@user.DateOfBirth.ToShortDateString()</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<ServiceUserDto>? serviceUsers;
    private CreateServiceUserDto newServiceUser = new();
    private string searchText = string.Empty;

    private List<ServiceUserDto> FilteredServiceUsers
    {
        get
        {
            if (serviceUsers is null)
                return new List<ServiceUserDto>();

            if (string.IsNullOrWhiteSpace(searchText))
                return serviceUsers;

            return serviceUsers
                .Where(user =>
                    user.FirstName.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                    user.LastName.Contains(searchText, StringComparison.OrdinalIgnoreCase))
                .ToList();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsLoggedIn)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        await LoadServiceUsers();
    }

    private async Task LoadServiceUsers()
    {
        serviceUsers = await ServiceUserService.GetAllAsync();
    }

    private async Task CreateServiceUser()
    {
        var success = await ServiceUserService.CreateAsync(newServiceUser);

        if (success)
        {
            newServiceUser = new CreateServiceUserDto();
            await LoadServiceUsers();
        }
    }

    private void ClearSearch()
    {
        searchText = string.Empty;
    }
}