@using SocialCareManager.Web.Services
@using System.Net.Http.Headers
@inject AuthService AuthService
@page "/serviceusers"
@rendermode InteractiveServer
@using System.Net.Http.Json
@inject HttpClient Http

<h1>Service users</h1>

<h4>Add service user</h4>

<div class="mb-3">
    <label class="form-label">First name</label>
    <input class="form-control" @bind="newServiceUser.FirstName" />
</div>

<div class="mb-3">
    <label class="form-label">Last name</label>
    <input class="form-control" @bind="newServiceUser.LastName" />
</div>

<div class="mb-3">
    <label class="form-label">Date of birth</label>
    <input type="date" class="form-control" @bind="newServiceUser.DateOfBirth" />
</div>

<button class="btn btn-primary mb-4" @onclick="CreateServiceUser">
    Add Service User
</button>

@if (serviceUsers is null)
{
    <p>Loading...</p>
}
else if (serviceUsers.Count == 0)
{
    <p>No service users found.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>First name</th>
                <th>Last name</th>
                <th>Date of birth</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in serviceUsers)
            {
                <tr>
                    <td>
                        <a href="@($"/serviceusers/{user.Id}")">@user.FirstName</a>
                    </td>
                    <td>@user.LastName</td>
                    <td>@user.DateOfBirth.ToShortDateString()</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<ServiceUserDto>? serviceUsers;
    private CreateServiceUserDto newServiceUser = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadServiceUsers();
    }

    private async Task LoadServiceUsers()
{
    if (!AuthService.IsLoggedIn)
        return;

    Http.DefaultRequestHeaders.Authorization =
        new AuthenticationHeaderValue("Bearer", AuthService.AccessToken);

    serviceUsers = await Http.GetFromJsonAsync<List<ServiceUserDto>>(
        "http://localhost:5195/api/serviceusers");
}

    private async Task CreateServiceUser()
    {
        var response = await Http.PostAsJsonAsync(
            "http://localhost:5195/api/serviceusers",
            newServiceUser);

        if (response.IsSuccessStatusCode)
        {
            newServiceUser = new CreateServiceUserDto();
            await LoadServiceUsers();
        }
    }

    public class ServiceUserDto
    {
        public Guid Id { get; set; }
        public string FirstName { get; set; } = string.Empty;
        public string LastName { get; set; } = string.Empty;
        public DateTime DateOfBirth { get; set; }
    }

    public class CreateServiceUserDto
    {
        public string FirstName { get; set; } = string.Empty;
        public string LastName { get; set; } = string.Empty;
        public DateTime DateOfBirth { get; set; } = DateTime.Today;
    }
}