@page "/serviceusers"
@rendermode InteractiveServer
@using System.Net.Http.Json
@using System.Net.Http.Headers
@using SocialCareManager.Web.Services
@inject HttpClient Http
@inject AuthService AuthService
@inject NavigationManager Navigation

<div class="page-header">
    <div class="page-title">
        <i class="bi bi-people-fill"></i>
        <h1>Service Users</h1>
    </div>

    <div class="page-subtitle">
        Manage service users, personal information and care records.
    </div>
</div>

<div class="section-card mb-4">
    <div class="section-card-header">
        <i class="bi bi-person-plus-fill"></i>
        <h3>Add service user</h3>
    </div>

    <div class="mb-3">
        <label class="form-label">First name</label>
        <input class="form-control" @bind="newServiceUser.FirstName" />
    </div>

    <div class="mb-3">
        <label class="form-label">Last name</label>
        <input class="form-control" @bind="newServiceUser.LastName" />
    </div>

    <div class="mb-3">
        <label class="form-label">Date of birth</label>
        <input type="date" class="form-control" @bind="newServiceUser.DateOfBirth" />
    </div>

    <button class="btn btn-primary" @onclick="CreateServiceUser">
        Add Service User
    </button>
</div>
<hr />

<h4>Search</h4>

<div class="mb-3">
    <input class="form-control"
           placeholder="Search by first name or last name..."
           @bind="searchText"
           @bind:event="oninput" />
</div>

<button class="btn btn-outline-secondary mb-4" @onclick="ClearSearch">
    Clear search
</button>

@if (serviceUsers is null)
{
    <p>Loading...</p>
}
else if (FilteredServiceUsers.Count == 0)
{
    <p>No service users found.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>First name</th>
                <th>Last name</th>
                <th>Date of birth</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in FilteredServiceUsers)
            {
                <tr>
                    <td>
                        <a href="@($"/serviceusers/{user.Id}")">@user.FirstName</a>
                    </td>
                    <td>@user.LastName</td>
                    <td>@user.DateOfBirth.ToShortDateString()</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<ServiceUserDto>? serviceUsers;
    private CreateServiceUserDto newServiceUser = new();
    private string searchText = string.Empty;

    private List<ServiceUserDto> FilteredServiceUsers
    {
        get
        {
            if (serviceUsers is null)
                return new List<ServiceUserDto>();

            if (string.IsNullOrWhiteSpace(searchText))
                return serviceUsers;

            return serviceUsers
                .Where(user =>
                    user.FirstName.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                    user.LastName.Contains(searchText, StringComparison.OrdinalIgnoreCase))
                .ToList();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsLoggedIn)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        await LoadServiceUsers();
    }

    private async Task LoadServiceUsers()
    {
        Http.DefaultRequestHeaders.Authorization =
            new AuthenticationHeaderValue("Bearer", AuthService.AccessToken);

        serviceUsers = await Http.GetFromJsonAsync<List<ServiceUserDto>>(
            "http://localhost:5195/api/serviceusers");
    }

    private async Task CreateServiceUser()
    {
        Http.DefaultRequestHeaders.Authorization =
            new AuthenticationHeaderValue("Bearer", AuthService.AccessToken);

        var response = await Http.PostAsJsonAsync(
            "http://localhost:5195/api/serviceusers",
            newServiceUser);

        if (response.IsSuccessStatusCode)
        {
            newServiceUser = new CreateServiceUserDto();
            await LoadServiceUsers();
        }
    }

    private void ClearSearch()
    {
        searchText = string.Empty;
    }

    public class ServiceUserDto
    {
        public Guid Id { get; set; }
        public string FirstName { get; set; } = string.Empty;
        public string LastName { get; set; } = string.Empty;
        public DateTime DateOfBirth { get; set; }
    }

    public class CreateServiceUserDto
    {
        public string FirstName { get; set; } = string.Empty;
        public string LastName { get; set; } = string.Empty;
        public DateTime DateOfBirth { get; set; } = DateTime.Today;
    }
}