@page "/"
@rendermode InteractiveServer
@using System.Net.Http.Json
@using System.Net.Http.Headers
@using SocialCareManager.Web.Services

@inject HttpClient Http
@inject AuthService AuthService

<PageTitle>Dashboard</PageTitle>

<div class="dashboard-header mb-4">
    <div>
        <h1 class="dashboard-title">
            <i class="bi bi-speedometer2 me-2"></i>
            Dashboard
        </h1>
        <p class="dashboard-subtitle">
            Welcome back. Here's an overview of your social care workspace.
        </p>
    </div>
</div>

@if (!AuthService.IsLoggedIn)
{
    <p>Please login to continue.</p>
    <a class="btn btn-primary" href="/login">Go to Login</a>
}
else if (isLoading)
{
    <p>Loading dashboard...</p>
}
else
{
    <p class="text-muted">
        Logged in as: <strong>@AuthService.Email</strong><br />
        Role: <strong>@AuthService.Role</strong>
    </p>

    <div class="row mb-4">
    <div class="col-md-3 mb-3">
        <div class="card p-3 h-100 shadow-sm">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-muted">Service Users</h6>
                    <h2>@serviceUserCount</h2>
                </div>
                <span class="fs-1">👥</span>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card p-3 h-100 shadow-sm">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-muted">Daily Notes</h6>
                    <h2>@dailyNoteCount</h2>
                </div>
                <span class="fs-1">📝</span>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card p-3 h-100 shadow-sm">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-muted">Next of Kin</h6>
                    <h2>@nextOfKinCount</h2>
                </div>
                <span class="fs-1">👨‍👩‍👧</span>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card p-3 h-100 shadow-sm">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-muted">Emergency Contacts</h6>
                    <h2>@emergencyContactCount</h2>
                </div>
                <span class="fs-1">🚨</span>
            </div>
        </div>
    </div>
</div>

    <h4>Quick actions</h4>

    <a class="btn btn-primary me-2 mb-3" href="/serviceusers">
        Service Users
    </a>

    <hr />

    <h4>Recent Daily Notes</h4>

    @if (recentNotes.Count == 0)
    {
        <p>No recent notes found.</p>
    }
    else
    {
        <ul class="list-group">
            @foreach (var note in recentNotes)
            {
                <li class="list-group-item">
                    <strong>@note.Title</strong><br />
                    <span class="text-muted">
                        @note.ServiceUserName —
                        @note.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                    </span>
                    <br />
                    @note.Content
                </li>
            }
        </ul>
    }
}

@code {
    private bool isLoading = true;

    private int serviceUserCount;
    private int dailyNoteCount;
    private int nextOfKinCount;
    private int emergencyContactCount;

    private List<RecentDailyNoteDto> recentNotes = new();

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsLoggedIn)
        {
            isLoading = false;
            return;
        }

        Http.DefaultRequestHeaders.Authorization =
            new AuthenticationHeaderValue("Bearer", AuthService.AccessToken);

        var serviceUsers = await Http.GetFromJsonAsync<List<ServiceUserDto>>(
            "http://localhost:5195/api/serviceusers");

        serviceUserCount = serviceUsers?.Count ?? 0;

        if (serviceUsers is not null)
        {
            foreach (var user in serviceUsers)
            {
                var notes = await Http.GetFromJsonAsync<List<DailyNoteDto>>(
                    $"http://localhost:5195/api/serviceusers/{user.Id}/dailynotes");

                dailyNoteCount += notes?.Count ?? 0;

                if (notes is not null)
                {
                    recentNotes.AddRange(notes.Select(note => new RecentDailyNoteDto
                    {
                        Title = note.Title,
                        Content = note.Content,
                        CreatedAt = note.CreatedAt,
                        ServiceUserName = $"{user.FirstName} {user.LastName}"
                    }));
                }

                var contacts = await Http.GetFromJsonAsync<List<NextOfKinDto>>(
                    $"http://localhost:5195/api/serviceusers/{user.Id}/nextofkin");

                nextOfKinCount += contacts?.Count ?? 0;
                emergencyContactCount += contacts?.Count(x => x.IsEmergencyContact) ?? 0;
            }
        }

        recentNotes = recentNotes
            .OrderByDescending(x => x.CreatedAt)
            .Take(5)
            .ToList();

        isLoading = false;
    }

    public class ServiceUserDto
    {
        public Guid Id { get; set; }
        public string FirstName { get; set; } = string.Empty;
        public string LastName { get; set; } = string.Empty;
    }

    public class DailyNoteDto
    {
        public string Title { get; set; } = string.Empty;
        public string Content { get; set; } = string.Empty;
        public DateTime CreatedAt { get; set; }
    }

    public class NextOfKinDto
    {
        public bool IsEmergencyContact { get; set; }
    }

    public class RecentDailyNoteDto
    {
        public string Title { get; set; } = string.Empty;
        public string Content { get; set; } = string.Empty;
        public DateTime CreatedAt { get; set; }
        public string ServiceUserName { get; set; } = string.Empty;
    }
}