<div class="text-center py-5">

    <i class="@Icon display-4 text-secondary"></i>

    <h4 class="mt-3">@Title</h4>

    <p class="text-muted">

        @Description

    </p>

</div>

@code{

    [Parameter]
    public string Title { get; set; } = "";

    [Parameter]
    public string Description { get; set; } = "";

    [Parameter]
    public string Icon { get; set; } = "bi bi-inbox";

}