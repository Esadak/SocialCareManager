@inject NavigationManager Navigation
@rendermode InteractiveServer
@using SocialCareManager.Web.Services
@inject AuthService AuthService

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">
            SocialCareManager
        </a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <i class="bi bi-house-door-fill me-2"></i>
                Home
            </NavLink>
        </div>

        @if (AuthService.IsLoggedIn)
        {
            <div class="sidebar-user-simple px-3">
    <div class="sidebar-user-name">Admin</div>
    <div class="sidebar-user-role">@AuthService.Role</div>
</div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="serviceusers">
                    <i class="bi bi-people-fill me-2"></i>
                    Service Users
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <button class="nav-link btn btn-link text-start w-100" @onclick="Logout">
                    <i class="bi bi-box-arrow-right me-2"></i>
                    Logout
                </button>
            </div>
        }
        else
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="login">
                    <i class="bi bi-box-arrow-in-right me-2"></i>
                    Login
                </NavLink>
            </div>
        }

    </nav>
</div>

@code {
    private void Logout()
    {
        AuthService.Logout();
        Navigation.NavigateTo("/login", forceLoad: true);
    }
}