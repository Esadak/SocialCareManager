@using System.Net.Http.Json
@using System.Net.Http.Headers
@using SocialCareManager.Web.Services
@inject HttpClient Http
@inject NavigationManager Navigation
@inject AuthService AuthService

@if (serviceUser is null)
{
    <p>Loading service user...</p>
}
else
{
    <h3>@serviceUser.FirstName @serviceUser.LastName</h3>
    <p><strong>Date of birth:</strong> @serviceUser.DateOfBirth.ToShortDateString()</p>

    @if (!isEditing)
    {
        <button class="btn btn-secondary mb-3" @onclick="StartEdit">
            Edit user
        </button>

        @if (AuthService.IsAdmin)
        {
            <button class="btn btn-danger mb-3 ms-2" @onclick="DeleteUser">
                Delete user
            </button>
        }
    }
    else
    {
        <h4>Edit service user</h4>

        <input class="form-control mb-2" @bind="editServiceUser.FirstName" />
        <input class="form-control mb-2" @bind="editServiceUser.LastName" />
        <input type="date" class="form-control mb-2" @bind="editServiceUser.DateOfBirth" />

        <button class="btn btn-primary me-2" @onclick="SaveUser">Save</button>
        <button class="btn btn-outline-secondary" @onclick="CancelEdit">Cancel</button>
    }
}

@code {
    [Parameter]
    public Guid ServiceUserId { get; set; }

    private ServiceUserDto? serviceUser;
    private EditServiceUserDto editServiceUser = new();
    private bool isEditing;

    protected override async Task OnInitializedAsync()
    {
        await LoadServiceUser();
    }

    private void SetAuthorizationHeader()
    {
        Http.DefaultRequestHeaders.Authorization =
            new AuthenticationHeaderValue("Bearer", AuthService.AccessToken);
    }

    private async Task LoadServiceUser()
    {
        SetAuthorizationHeader();

        serviceUser = await Http.GetFromJsonAsync<ServiceUserDto>(
            $"http://localhost:5195/api/serviceusers/{ServiceUserId}");
    }

    private void StartEdit()
    {
        if (serviceUser is null)
            return;

        editServiceUser = new EditServiceUserDto
        {
            FirstName = serviceUser.FirstName,
            LastName = serviceUser.LastName,
            DateOfBirth = serviceUser.DateOfBirth
        };

        isEditing = true;
    }

    private void CancelEdit()
    {
        isEditing = false;
    }

    private async Task SaveUser()
    {
        SetAuthorizationHeader();

        var response = await Http.PutAsJsonAsync(
            $"http://localhost:5195/api/serviceusers/{ServiceUserId}",
            editServiceUser);

        if (response.IsSuccessStatusCode)
        {
            await LoadServiceUser();
            isEditing = false;
        }
    }

    private async Task DeleteUser()
    {
        SetAuthorizationHeader();

        var response = await Http.DeleteAsync(
            $"http://localhost:5195/api/serviceusers/{ServiceUserId}");

        if (response.IsSuccessStatusCode)
        {
            Navigation.NavigateTo("/serviceusers");
        }
    }

    private class ServiceUserDto
    {
        public Guid Id { get; set; }
        public string FirstName { get; set; } = string.Empty;
        public string LastName { get; set; } = string.Empty;
        public DateTime DateOfBirth { get; set; }
    }

    private class EditServiceUserDto
    {
        public string FirstName { get; set; } = string.Empty;
        public string LastName { get; set; } = string.Empty;
        public DateTime DateOfBirth { get; set; }
    }
}