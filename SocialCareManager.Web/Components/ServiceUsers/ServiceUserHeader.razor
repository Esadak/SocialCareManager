@using SocialCareManager.Web.Dtos
@using System.Net.Http.Json
@using System.Net.Http.Headers
@using SocialCareManager.Web.Services
@using SocialCareManager.Web.Components.Common
@inject HttpClient Http
@inject NavigationManager Navigation
@inject AuthService AuthService

@if (serviceUser is null)
{
    <div class="section-card mb-4">
        <p class="mb-0">Loading service user...</p>
    </div>
}
else
{
    <div class="profile-card mb-4">
        <div class="profile-main">
            <div class="profile-avatar">
                <i class="bi bi-person-fill"></i>
            </div>

            <div>
                <h2 class="profile-name">
                    @serviceUser.FirstName @serviceUser.LastName
                </h2>

                <div class="profile-subtitle">
                    Service user profile
                </div>
            </div>
        </div>

        <div class="profile-details">
            <div class="profile-detail">
                <span>Date of birth</span>
                <strong>@serviceUser.DateOfBirth.ToShortDateString()</strong>
            </div>

            <div class="profile-detail">
                <span>Age</span>
                <strong>@CalculateAge(serviceUser.DateOfBirth)</strong>
            </div>

            <div class="profile-detail">
                <span>Status</span>
                <strong class="status-active">
                    <i class="bi bi-circle-fill"></i>
                    Active
                </strong>
            </div>
        </div>

        @if (!isEditing)
        {
            <div class="profile-actions">
                <button class="btn btn-secondary" @onclick="StartEdit">
                    <i class="bi bi-pencil-square me-1"></i>
                    Edit user
                </button>

                @if (AuthService.IsAdmin)
                {
                    <button class="btn btn-danger ms-2" @onclick="DeleteUser">
                        <i class="bi bi-trash3-fill me-1"></i>
                        Delete user
                    </button>
                }
            </div>
        }
        else
        {
            <div class="profile-edit mt-4">

    <SectionHeader
        Title="Edit service user"
        Icon="bi bi-pencil-square" />

    <input class="form-control mb-2" @bind="editServiceUser.FirstName" />
    <input class="form-control mb-2" @bind="editServiceUser.LastName" />
    <input type="date" class="form-control mb-3" @bind="editServiceUser.DateOfBirth" />

    <button class="btn btn-primary me-2" @onclick="SaveUser">
        Save
    </button>

    <button class="btn btn-outline-secondary" @onclick="CancelEdit">
        Cancel
    </button>

</div>
        }
    </div>
}

@code {
    [Parameter]
    public Guid ServiceUserId { get; set; }

    private ServiceUserDto? serviceUser;
    private EditServiceUserDto editServiceUser = new();
    private bool isEditing;

    protected override async Task OnInitializedAsync()
    {
        await LoadServiceUser();
    }

    private void SetAuthorizationHeader()
    {
        Http.DefaultRequestHeaders.Authorization =
            new AuthenticationHeaderValue("Bearer", AuthService.AccessToken);
    }

    private async Task LoadServiceUser()
    {
        SetAuthorizationHeader();

        serviceUser = await Http.GetFromJsonAsync<ServiceUserDto>(
            $"http://localhost:5195/api/serviceusers/{ServiceUserId}");
    }

    private void StartEdit()
    {
        if (serviceUser is null)
            return;

        editServiceUser = new EditServiceUserDto
        {
            FirstName = serviceUser.FirstName,
            LastName = serviceUser.LastName,
            DateOfBirth = serviceUser.DateOfBirth
        };

        isEditing = true;
    }

    private void CancelEdit()
    {
        isEditing = false;
    }

    private async Task SaveUser()
    {
        SetAuthorizationHeader();

        var response = await Http.PutAsJsonAsync(
            $"http://localhost:5195/api/serviceusers/{ServiceUserId}",
            editServiceUser);

        if (response.IsSuccessStatusCode)
        {
            await LoadServiceUser();
            isEditing = false;
        }
    }

    private async Task DeleteUser()
    {
        SetAuthorizationHeader();

        var response = await Http.DeleteAsync(
            $"http://localhost:5195/api/serviceusers/{ServiceUserId}");

        if (response.IsSuccessStatusCode)
        {
            Navigation.NavigateTo("/serviceusers");
        }
    }

    private static int CalculateAge(DateTime dateOfBirth)
    {
        var today = DateTime.Today;
        var age = today.Year - dateOfBirth.Year;

        if (dateOfBirth.Date > today.AddYears(-age))
        {
            age--;
        }

        return age;
    }

}