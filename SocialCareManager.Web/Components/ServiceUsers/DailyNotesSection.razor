@using SocialCareManager.Web.Dtos.DailyNotes
@using SocialCareManager.Web.Services.Api
@using SocialCareManager.Web.Components.Common
@inject IJSRuntime JS
@inject DailyNoteService DailyNoteService


<SectionCard>
    <SectionHeader Title="Daily Notes" Icon="bi bi-journal-text" />

    <input class="form-control mb-2" placeholder="Title" @bind="newNote.Title" />
    <textarea class="form-control mb-3" rows="3" placeholder="Content" @bind="newNote.Content"></textarea>

    <button class="btn btn-primary" @onclick="CreateNote">
        <i class="bi bi-plus-circle me-1"></i>
        Add Daily Note
    </button>
</SectionCard>

@if (dailyNotes is null)
{
    <SectionCard>
        <p class="mb-0">Loading notes...</p>
    </SectionCard>
}
else if (dailyNotes.Count == 0)
{
    <div class="section-card">
        <p class="mb-0 text-muted">No daily notes found.</p>
    </div>
}
else
{
    <div class="notes-list">
        @foreach (var note in dailyNotes)
        {
            <div class="note-card">
                @if (editingNoteId == note.Id)
                {
                    <SectionHeader Title="Edit daily note" Icon="bi bi-pencil-square" />

                    <input class="form-control mb-2" @bind="editNote.Title" />
                    <textarea class="form-control mb-3" rows="3" @bind="editNote.Content"></textarea>

                    <button class="btn btn-primary btn-sm me-2" @onclick="SaveNote">
                        Save
                    </button>

                    <button class="btn btn-outline-secondary btn-sm" @onclick="CancelEditNote">
                        Cancel
                    </button>
                }
                else
                {
                    <div class="note-card-header">
                        <div>
                            <h4>@note.Title</h4>

                            <div class="note-meta">
                                <i class="bi bi-clock me-1"></i>
                                @note.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")

                                @if (!string.IsNullOrWhiteSpace(note.CreatedBy))
                                {
                                    <span class="mx-2">•</span>
                                    <i class="bi bi-person me-1"></i>
                                    @note.CreatedBy
                                }
                            </div>
                        </div>
                    </div>

                    <p class="note-content">
                        @note.Content
                    </p>

                    @if (note.UpdatedAt is not null || !string.IsNullOrWhiteSpace(note.UpdatedBy))
                    {
                        <div class="note-updated">
                            Updated

                            @if (note.UpdatedAt is not null)
                            {
                                <span>
                                    @note.UpdatedAt.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                                </span>
                            }

                            @if (!string.IsNullOrWhiteSpace(note.UpdatedBy))
                            {
                                <span>by @note.UpdatedBy</span>
                            }
                        </div>
                    }

                    <div class="note-actions">
                        <button class="btn btn-secondary btn-sm me-2" @onclick="() => StartEditNote(note)">
                            <i class="bi bi-pencil-square me-1"></i>
                            Edit
                        </button>

                        <button class="btn btn-danger btn-sm" @onclick="() => DeleteNote(note.Id)">
                            <i class="bi bi-trash3-fill me-1"></i>
                            Delete
                        </button>
                    </div>
                }
            </div>
        }
    </div>
}

@code {
    [Parameter]
    public Guid ServiceUserId { get; set; }

    private List<DailyNoteDto>? dailyNotes;
    private CreateDailyNoteDto newNote = new();
    private EditDailyNoteDto editNote = new();
    private Guid? editingNoteId;

    protected override async Task OnInitializedAsync()
    {
        await LoadNotes();
    }

    private async Task LoadNotes()
    {
        dailyNotes = await DailyNoteService.GetAllAsync(ServiceUserId);
    }

    private async Task CreateNote()
    {
        var success = await DailyNoteService.CreateAsync(ServiceUserId, newNote);

        if (success)
        {
            newNote = new CreateDailyNoteDto();
            await LoadNotes();
        }
    }

    private void StartEditNote(DailyNoteDto note)
    {
        editingNoteId = note.Id;

        editNote = new EditDailyNoteDto
        {
            Title = note.Title,
            Content = note.Content
        };
    }

    private void CancelEditNote()
    {
        editingNoteId = null;
        editNote = new EditDailyNoteDto();
    }

    private async Task SaveNote()
    {
        if (editingNoteId is null)
            return;

        var success = await DailyNoteService.UpdateAsync(
            ServiceUserId,
            editingNoteId.Value,
            editNote);

        if (success)
        {
            editingNoteId = null;
            editNote = new EditDailyNoteDto();
            await LoadNotes();
        }
    }

    private async Task DeleteNote(Guid noteId)
    {
        var confirmed = await JS.InvokeAsync<bool>(
            "confirm",
            "Are you sure you want to delete this daily note?");

        if (!confirmed)
            return;

        var success = await DailyNoteService.DeleteAsync(ServiceUserId, noteId);

        if (success)
        {
            await LoadNotes();
        }
    }

    
}