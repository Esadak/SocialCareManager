@using System.Net.Http.Json
@using System.Net.Http.Headers
@using SocialCareManager.Web.Services
@using SocialCareManager.Web.Components.Common
@inject HttpClient Http
@inject IJSRuntime JS
@inject AuthService AuthService

<h4>Next of Kin</h4>

<input class="form-control mb-2" placeholder="Full name" @bind="newContact.FullName" />
<input class="form-control mb-2" placeholder="Relationship" @bind="newContact.Relationship" />
<input class="form-control mb-2" placeholder="Phone number" @bind="newContact.PhoneNumber" />
<input class="form-control mb-2" placeholder="Email" @bind="newContact.Email" />
<input class="form-control mb-2" placeholder="Address" @bind="newContact.Address" />

<div class="form-check mb-3">
    <input class="form-check-input" type="checkbox" @bind="newContact.IsEmergencyContact" />
    <label class="form-check-label">Emergency contact</label>
</div>

<button class="btn btn-primary mb-3" @onclick="CreateContact">
    Add Next of Kin
</button>

@if (contacts is null)
{
    <p>Loading contacts...</p>
}
else if (contacts.Count == 0)
{
    <SectionCard>
    <SectionHeader Title="Next of Kin" Icon="bi bi-person-hearts" />
     </SectionCard>
}
else
{
    <div class="row">
    @foreach (var contact in contacts)
    {
        <div class="col-md-6 mb-3">
            <div class="card h-100">
                <div class="card-body">
                    @if (editingContactId == contact.Id)
                    {
                        <input class="form-control mb-2" @bind="editContact.FullName" />
                        <input class="form-control mb-2" @bind="editContact.Relationship" />
                        <input class="form-control mb-2" @bind="editContact.PhoneNumber" />
                        <input class="form-control mb-2" @bind="editContact.Email" />
                        <input class="form-control mb-2" @bind="editContact.Address" />

                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" @bind="editContact.IsEmergencyContact" />
                            <label class="form-check-label">Emergency contact</label>
                        </div>

                        <button class="btn btn-primary btn-sm me-2" @onclick="SaveContact">
                            Save
                        </button>

                        <button class="btn btn-outline-secondary btn-sm" @onclick="CancelEdit">
                            Cancel
                        </button>
                    }
                    else
                    {
                        <h5 class="card-title">@contact.FullName</h5>
                        <h6 class="card-subtitle mb-2 text-muted">@contact.Relationship</h6>

                        @if (contact.IsEmergencyContact)
                        {
                            <span class="badge bg-danger fs-6">Emergency contact</span>
                        }

                        <p class="card-text mb-1">
                            <strong>Phone:</strong> @contact.PhoneNumber
                        </p>

                        <p class="card-text mb-1">
                            <strong>Email:</strong> @contact.Email
                        </p>

                        <p class="card-text mb-3">
                            <strong>Address:</strong> @contact.Address
                        </p>

                        <button class="btn btn-secondary btn-sm me-2"
                                @onclick="@(() => StartEdit(contact))">
                            Edit
                        </button>

                        @if (AuthService.IsAdmin)
                        {
                            <button class="btn btn-danger btn-sm"
                                    @onclick="@(() => DeleteContact(contact.Id))">
                                Delete
                            </button>
                        }
                    }
                </div>
            </div>
        </div>
    }
</div>
}

@code {
    [Parameter]
    public Guid ServiceUserId { get; set; }

    private List<NextOfKinDto>? contacts;
    private CreateNextOfKinDto newContact = new();
    private EditNextOfKinDto editContact = new();
    private Guid? editingContactId;

    protected override async Task OnInitializedAsync()
    {
        await LoadContacts();
    }

    private void SetAuthorizationHeader()
    {
        Http.DefaultRequestHeaders.Authorization =
            new AuthenticationHeaderValue("Bearer", AuthService.AccessToken);
    }

    private async Task LoadContacts()
    {
        SetAuthorizationHeader();

        contacts = await Http.GetFromJsonAsync<List<NextOfKinDto>>(
            $"http://localhost:5195/api/serviceusers/{ServiceUserId}/nextofkin");
    }

    private async Task CreateContact()
    {
        SetAuthorizationHeader();

        var response = await Http.PostAsJsonAsync(
            $"http://localhost:5195/api/serviceusers/{ServiceUserId}/nextofkin",
            newContact);

        if (response.IsSuccessStatusCode)
        {
            newContact = new CreateNextOfKinDto();
            await LoadContacts();
        }
    }

    private void StartEdit(NextOfKinDto contact)
    {
        editingContactId = contact.Id;

        editContact = new EditNextOfKinDto
        {
            FullName = contact.FullName,
            Relationship = contact.Relationship,
            PhoneNumber = contact.PhoneNumber,
            Email = contact.Email,
            Address = contact.Address,
            IsEmergencyContact = contact.IsEmergencyContact
        };
    }

    private void CancelEdit()
    {
        editingContactId = null;
        editContact = new EditNextOfKinDto();
    }

    private async Task SaveContact()
    {
        if (editingContactId is null)
            return;

        SetAuthorizationHeader();

        var response = await Http.PutAsJsonAsync(
            $"http://localhost:5195/api/serviceusers/{ServiceUserId}/nextofkin/{editingContactId}",
            editContact);

        if (response.IsSuccessStatusCode)
        {
            editingContactId = null;
            editContact = new EditNextOfKinDto();
            await LoadContacts();
        }
    }

    private async Task DeleteContact(Guid contactId)
    {
        var confirmed = await JS.InvokeAsync<bool>(
            "confirm",
            "Are you sure you want to delete this next of kin?");

        if (!confirmed)
            return;

        SetAuthorizationHeader();

        var response = await Http.DeleteAsync(
            $"http://localhost:5195/api/serviceusers/{ServiceUserId}/nextofkin/{contactId}");

        if (response.IsSuccessStatusCode)
        {
            await LoadContacts();
        }
    }

    private class NextOfKinDto
    {
        public Guid Id { get; set; }
        public Guid ServiceUserId { get; set; }
        public string FullName { get; set; } = string.Empty;
        public string Relationship { get; set; } = string.Empty;
        public string PhoneNumber { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string Address { get; set; } = string.Empty;
        public bool IsEmergencyContact { get; set; }
        public DateTime CreatedAt { get; set; }
        public DateTime? UpdatedAt { get; set; }
    }

    private class CreateNextOfKinDto
    {
        public string FullName { get; set; } = string.Empty;
        public string Relationship { get; set; } = string.Empty;
        public string PhoneNumber { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string Address { get; set; } = string.Empty;
        public bool IsEmergencyContact { get; set; }
    }

    private class EditNextOfKinDto
    {
        public string FullName { get; set; } = string.Empty;
        public string Relationship { get; set; } = string.Empty;
        public string PhoneNumber { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string Address { get; set; } = string.Empty;
        public bool IsEmergencyContact { get; set; }
    }
}