@using SocialCareManager.Web.Components.Common
@using SocialCareManager.Web.Dtos
@using SocialCareManager.Web.Services.Api

@inject CarePlanService CarePlanService

@if (carePlan is null && !isCreating)
{
    <SectionCard>
        <SectionHeader Title="Care Plan" Icon="bi bi-clipboard2-check-fill" />

        <p class="text-muted">
            No active care plan has been created for this service user yet.
        </p>

        <button class="btn btn-primary" @onclick="StartCreate">
            <i class="bi bi-plus-circle me-1"></i>
            Create Care Plan
        </button>
    </SectionCard>
}
else if (isCreating)
{
    <SectionCard>
        <SectionHeader Title="Create Care Plan" Icon="bi bi-plus-circle" />

        <div class="mb-3">
            <label class="form-label">Goal</label>
            <textarea class="form-control" rows="3" @bind="newCarePlan.Goal"></textarea>
        </div>

        <div class="mb-3">
            <label class="form-label">Needs</label>
            <textarea class="form-control" rows="3" @bind="newCarePlan.Needs"></textarea>
        </div>

        <div class="mb-3">
            <label class="form-label">Support Plan</label>
            <textarea class="form-control" rows="3" @bind="newCarePlan.SupportPlan"></textarea>
        </div>

        <div class="mb-3">
            <label class="form-label">Risk Assessment</label>
            <textarea class="form-control" rows="3" @bind="newCarePlan.RiskAssessment"></textarea>
        </div>

        <div class="mb-3">
            <label class="form-label">Review Date</label>
            <input type="date" class="form-control" @bind="newCarePlan.ReviewDate" />
        </div>

        <button class="btn btn-primary me-2" @onclick="CreateCarePlan">
            Save Care Plan
        </button>

        <button class="btn btn-outline-secondary" @onclick="CancelCreate">
            Cancel
        </button>
    </SectionCard>
}
else if (carePlan is not null)
{
    <SectionCard>

        <div class="section-card-header">
            <i class="bi bi-clipboard2-check-fill"></i>
            <h3>Care Plan</h3>
        </div>

        <div class="care-plan-summary mb-4">

            <div class="care-plan-summary-item">
                <span>Status</span>
                <strong class="text-success">
                    <i class="bi bi-circle-fill me-1"></i>
                    Active
                </strong>
            </div>

            <div class="care-plan-summary-item">
                <span>Review</span>
                <strong>@GetReviewStatusText()</strong>
            </div>

            <div class="care-plan-summary-item">
                <span>Created by</span>
                <strong>@(carePlan.CreatedBy ?? "Unknown")</strong>
            </div>

            <div class="care-plan-summary-item">
                <span>Last updated</span>
                <strong>
                    @(carePlan.UpdatedAt is null
                        ? "Not updated"
                        : carePlan.UpdatedAt.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm"))
                </strong>
            </div>

        </div>

        <div class="@GetReviewStatusClass() mb-4">
            <i class="bi bi-calendar-check me-2"></i>

            <div>
                <strong>@GetReviewStatusText()</strong>

                <div class="text-muted small">
                    Next review: @carePlan.ReviewDate.ToShortDateString()
                </div>
            </div>
        </div>

        <div class="row g-4">

            <div class="col-lg-6">
                <InfoCard Title="Goal" Icon="bi bi-bullseye">
                    @carePlan.Goal
                </InfoCard>
            </div>

            <div class="col-lg-6">
                <InfoCard Title="Needs" Icon="bi bi-heart-fill">
                    @carePlan.Needs
                </InfoCard>
            </div>

            <div class="col-lg-6">
                <InfoCard Title="Support Plan" Icon="bi bi-people-fill">
                    @carePlan.SupportPlan
                </InfoCard>
            </div>

            <div class="col-lg-6">
                <InfoCard Title="Risk Assessment" Icon="bi bi-exclamation-triangle-fill">
                    @carePlan.RiskAssessment
                </InfoCard>
            </div>

        </div>

    </SectionCard>
}

@code {

    [Parameter]
    public Guid ServiceUserId { get; set; }

    private CarePlanDto? carePlan;
    private CreateCarePlanDto newCarePlan = new();
    private bool isCreating;

    protected override async Task OnInitializedAsync()
    {
        await LoadCarePlan();
    }

    private async Task LoadCarePlan()
    {
        carePlan = await CarePlanService.GetActiveAsync(ServiceUserId);
    }

    private void StartCreate()
    {
        newCarePlan = new CreateCarePlanDto();
        isCreating = true;
    }

    private void CancelCreate()
    {
        isCreating = false;
        newCarePlan = new CreateCarePlanDto();
    }

    private async Task CreateCarePlan()
    {
        var success = await CarePlanService.CreateAsync(ServiceUserId, newCarePlan);

        if (success)
        {
            isCreating = false;
            newCarePlan = new CreateCarePlanDto();

            await LoadCarePlan();
        }
    }

    private string GetReviewStatusText()
    {
        if (carePlan is null)
            return string.Empty;

        var daysRemaining = (carePlan.ReviewDate.Date - DateTime.Today).Days;

        if (daysRemaining < 0)
            return $"Overdue by {Math.Abs(daysRemaining)} days";

        if (daysRemaining == 0)
            return "Review due today";

        if (daysRemaining <= 7)
            return $"Review in {daysRemaining} days";

        return $"{daysRemaining} days remaining";
    }

    private string GetReviewStatusClass()
    {
        if (carePlan is null)
            return "review-status";

        var daysRemaining = (carePlan.ReviewDate.Date - DateTime.Today).Days;

        if (daysRemaining < 0)
            return "review-status danger";

        if (daysRemaining <= 7)
            return "review-status warning";

        return "review-status success";
    }
}